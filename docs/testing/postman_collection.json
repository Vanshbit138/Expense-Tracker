              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 30.00,\n  \"description\": \"Updated lunch at restaurant\",\n  \"status\": \"approved\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/expenses/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "expenses", "1"]
            }
          }
        }
      ]
