              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Food & Dining\",\n  \"description\": \"Updated description for food expenses\",\n  \"color\": \"#FF5733\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/categories/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "categories", "1"]
            }
          }
        }
